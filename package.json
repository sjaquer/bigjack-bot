{
  "name": "bigjack-bot",
  "version": "1.3.0",
  "description": "Big Jack Bot - Hybrid Desktop App (Electron + WhatsApp Web)",
  "main": "electron-main.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "electron": "electron .",
    "dist": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.bigjack.bot",
    "productName": "Big Jack Bot",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "public/icon.png"
    },
    "files": [
      "**/*",
      "!dist/*"
    ]
  },
  "keywords": [
    "whatsapp",
    "bot",
    "ai",
    "electron",
    "restaurant"
  ],
  "author": "Sebastián Jaque",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.16.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.8.3",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "nodemon": "^3.1.0"
  }
}
