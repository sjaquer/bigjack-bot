# --- WHATSAPP CONFIG ---
# Puerto o ruta si es necesario (opcional)
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# --- AI PROVIDER CONFIG ---
# Opciones: 'gemini' o 'ollama'
AI_PROVIDER=gemini

# --- GEMINI CONFIG ---
GEMINI_API_KEY=tu_api_key_aqui
GEMINI_MODELS=gemini-2.0-flash,gemini-1.5-flash

# --- OLLAMA CONFIG ---
# URL por defecto: http://localhost:11434/api/chat
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3

# --- ERP / WEBHOOK CONFIG ---
WEBHOOK_URL=https://tu-erp.com/webhook
WEBHOOK_SECRET=un_secreto_seguro
